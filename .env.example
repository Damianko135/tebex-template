# Redis connection string for persisted theme storage. Falls back to an
# in-memory store (dev only, not shared across instances) when unset.
REDIS_URL=

# Your Tebex webstore's public token, used to scope every Headless API
# request (https://headless.tebex.io/api/accounts/{token}). Required for
# the admin dashboard to show live store data.
TEBEX_STORE_TOKEN=

# --- Admin authentication (Better Auth) ---
# Protects /admin/* only. Tebex customer accounts, baskets, and checkout are
# unaffected and continue to be handled entirely by Tebex.

# Secret used to sign/encrypt sessions and cookies. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# The base URL this app is served from (used to build auth callback URLs).
BETTER_AUTH_URL=http://localhost:3000

# Bootstrap credentials for the very first administrator account, used once
# by `ensureInitialAdmin()` (see lib/auth-bootstrap.ts) the first time the
# server starts with no administrators yet. After that account exists, these
# variables have no further effect - sign-in always goes through Better Auth,
# never a direct comparison against these values.
#
# Login is by username (v1). Better Auth's `minPasswordLength` defaults to 8
# characters - a short password like "admin" will be rejected unless you
# lower that in lib/auth.ts.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional. Better Auth's user schema always has an email column even though
# the login form only asks for a username; if unset, one is synthesized as
# "{username}@admin.local" and never shown in the UI.
ADMIN_EMAIL=
